{
  "name": "ftc-atem-switcher",
  "version": "1.0.0",
  "description": "Automatically switch Blackmagic ATEM cameras between FTC competition fields based on match progress",
  "main": "electron-main.js",
  "scripts": {
    "start": "node src/index.js",
    "dry-run": "node src/index.js --dry-run",
    "test-api": "node src/test-api.js",
    "electron:dev": "electron .",
    "electron:build": "electron-builder --win",
    "build:cli": "pkg . --targets node18-win-x64 --output dist/ftc-atem-switcher-cli.exe"
  },
  "build": {
    "appId": "com.nycfirst.ftc-atem-switcher",
    "productName": "FTC ATEM Switcher",
    "directories": {
      "output": "dist"
    },
    "npmRebuild": false,
    "files": [
      "electron-main.js",
      "src/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "FTC-ATEM-Switcher-Setup.exe"
    }
  },
  "keywords": [
    "ftc",
    "atem",
    "first",
    "robotics",
    "livestream",
    "blackmagic"
  ],
  "license": "CC-BY-NC-SA-4.0",
  "dependencies": {
    "atem-connection": "^3.6.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "pkg": "^5.8.1"
  }
}