# FTC Events API Credentials
# Register at: https://ftc-api.firstinspires.org/services/API/register
FTC_USERNAME=your_username_here
FTC_AUTH_KEY=your_auth_key_here

# Event Configuration
FTC_SEASON=2025
FTC_EVENT_CODE=YOUR_EVENT_CODE
FTC_TOURNAMENT_LEVEL=qual

# ATEM Switcher Configuration
ATEM_IP=192.168.10.240

# Field-to-Input Mapping (ATEM input numbers, 1-8)
FIELD1_INPUT=1
FIELD2_INPUT=3

# Polling interval in milliseconds
POLL_INTERVAL_MS=5000

# Dashboard port
DASHBOARD_PORT=3000
